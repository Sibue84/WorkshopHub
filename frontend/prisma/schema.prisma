generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Area {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  boxes     Box[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Box {
  id        String   @id
  areaId    Int
  shelf     String
  number    Int
  imagePath String?

  area      Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  items     Item[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([areaId, shelf, number])
  @@index([areaId])
}

model Item {
  id        Int      @id @default(autoincrement())
  name      String
  boxId     String
  box       Box      @relation(fields: [boxId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boxId])
  @@index([name])
}